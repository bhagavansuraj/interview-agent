---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="System Design Companion"
  description="Learn system design at the level that matters for your role — built for product managers and engineering leaders."
>
  <!-- NAV -->
  <header class="border-b border-gray-200">
    <div class="mx-auto flex max-w-4xl items-center px-6 py-5">
      <span class="text-sm font-semibold tracking-tight text-gray-900">
        System Design Companion
      </span>
    </div>
  </header>

  <!-- HERO -->
  <section class="mx-auto max-w-4xl px-6 py-20">
    <h1 class="mb-6 max-w-2xl text-5xl font-extrabold leading-tight tracking-tight text-gray-900 sm:text-6xl">
      System design, at your level.
    </h1>
    <p class="max-w-lg text-lg text-gray-500">
      A conversational AI that teaches system design the way you actually need
      to learn it — whether you're a product manager building intuition or an
      engineering leader sharpening your edge.
    </p>
  </section>

  <!-- TWO PATHS -->
  <section class="border-t border-gray-200">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <div class="grid gap-px bg-gray-200 sm:grid-cols-2">
        <!-- PM path -->
        <div class="flex flex-col bg-white p-10">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-gray-400">
            For product managers
          </p>
          <h2 class="mb-4 text-2xl font-bold tracking-tight text-gray-900">
            Build your system design intuition
          </h2>
          <p class="mb-8 flex-1 text-gray-500 leading-relaxed">
            Start from zero. Learn how the internet works, what databases and
            APIs actually do, and how to talk confidently with engineers —
            using plain English and real-world analogies throughout.
          </p>
          <div class="mb-6 space-y-2 text-sm text-gray-500">
            {
              [
                "The big picture & core building blocks",
                "Scaling, databases, APIs, caching",
                "Real-world design walkthroughs",
                "PM interview preparation",
              ].map((item) => (
                <div class="flex items-center gap-2">
                  <span class="text-gray-300">—</span>
                  {item}
                </div>
              ))
            }
          </div>
          <a
            href="/chat"
            class="inline-block rounded-full bg-gray-900 px-7 py-3 text-sm font-semibold text-white transition hover:bg-gray-700"
          >
            Start learning →
          </a>
        </div>

        <!-- Engineering leader path -->
        <div class="flex flex-col bg-white p-10">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-gray-400">
            For engineering leaders
          </p>
          <h2 class="mb-4 text-2xl font-bold tracking-tight text-gray-900">
            Sharpen your senior-level edge
          </h2>
          <p class="mb-8 flex-1 text-gray-500 leading-relaxed">
            Built for HoEs, senior EMs, and VPs. Go deep on distributed
            systems trade-offs, advanced architecture patterns, and the
            leadership dimensions that come up in senior interviews and
            day-to-day decisions.
          </p>
          <div class="mb-6 space-y-2 text-sm text-gray-500">
            {
              [
                "CAP theorem, consistency, fault tolerance",
                "Event sourcing, CQRS, saga patterns",
                "Multi-region, observability, reliability",
                "Staff/Principal/EM/VP interview prep",
              ].map((item) => (
                <div class="flex items-center gap-2">
                  <span class="text-gray-300">—</span>
                  {item}
                </div>
              ))
            }
          </div>
          <a
            href="/engineering"
            class="inline-block rounded-full border border-gray-900 px-7 py-3 text-sm font-semibold text-gray-900 transition hover:bg-gray-900 hover:text-white"
          >
            Start learning →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-gray-200">
    <div class="mx-auto max-w-4xl px-6 py-8">
      <p class="text-sm text-gray-400">
        &copy; {new Date().getFullYear()} System Design Companion · Powered by Claude
      </p>
    </div>
  </footer>
</Layout>
